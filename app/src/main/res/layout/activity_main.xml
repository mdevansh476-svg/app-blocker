<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <!-- Swappable Middle Content View -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_bar" />

    <!-- Permanent Fixed Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_navigation_bar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:weightSum="4">

        <!-- Tab 1: Focus -->
        <LinearLayout
            android:id="@+id/nav_tab_focus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_tab_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_nav_focus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ Focus"
                android:textColor="#8B5CF6"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 2: Apps -->
        <LinearLayout
            android:id="@+id/nav_tab_apps"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_nav_apps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 Apps"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 3: Stats -->
        <LinearLayout
            android:id="@+id/nav_tab_stats"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_nav_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Stats"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tab 4: About -->
        <LinearLayout
            android:id="@+id/nav_tab_about"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_nav_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ℹ️ About"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
