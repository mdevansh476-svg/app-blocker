<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:padding="24dp">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Builder"
            android:textColor="#F8FAFC"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/app_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Build habits • Eliminate distractions"
            android:textColor="#94A3B8"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Main Card Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/status_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Permissions &amp; Setup"
            android:textColor="#E2E8F0"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Grant access to enable app blocking and active focus sessions."
            android:textColor="#94A3B8"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_select_apps"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:text="Choose Apps to Block 📱"
            android:textAllCaps="false"
            android:textColor="#E2E8F0"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Timer Selector Controls -->
        <LinearLayout
            android:id="@+id/timer_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_15m"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_button"
                android:text="15m"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_25m"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_button"
                android:text="25m"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btn_45m"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button"
                android:text="45m"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Live Countdown View -->
        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="25:00"
            android:textColor="#6366F1"
            android:textSize="42sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_grant_permissions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button"
            android:text="Grant Permissions"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Footer Signature -->
    <TextView
        android:id="@+id/footer_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="12dp"
        android:letterSpacing="0.08"
        android:text="Made by Devansh"
        android:textColor="#64748B"
        android:textSize="13sp"
        android:textStyle="italic" />

</RelativeLayout>
