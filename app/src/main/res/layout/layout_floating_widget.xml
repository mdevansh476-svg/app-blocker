<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- Collapsed Floating Pill/Bubble -->
    <LinearLayout
        android:id="@+id/layout_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 "
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_overlay_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#F8FAFC"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Expanded Overlay Control Window -->
    <LinearLayout
        android:id="@+id/layout_expanded"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_expanded_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="#6366F1"
            android:textSize="22sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_overlay_pause"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_button"
            android:text="Pause"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_overlay_minimize"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:background="@null"
            android:text="Minimize ✖"
            android:textAllCaps="false"
            android:textColor="#94A3B8"
            android:textSize="11sp" />
    </LinearLayout>

</FrameLayout>
