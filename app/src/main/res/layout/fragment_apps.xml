<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/header_apps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Select Apps to Block 📱"
            android:textColor="#F8FAFC"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- App Search Bar -->
        <EditText
            android:id="@+id/et_search_apps"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:hint="Search installed apps..."
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="#F8FAFC"
            android:textColorHint="#64748B"
            android:textSize="14sp" />

        <!-- Category Select Bar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_group_social"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card"
                    android:paddingHorizontal="12dp"
                    android:text="💬 Social"
                    android:textAllCaps="false"
                    android:textColor="#E2E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_group_games"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_card"
                    android:paddingHorizontal="12dp"
                    android:text="🎮 Games"
                    android:textAllCaps="false"
                    android:textColor="#E2E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_group_streaming"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_card"
                    android:paddingHorizontal="12dp"
                    android:text="🎬 Video"
                    android:textAllCaps="false"
                    android:textColor="#E2E8F0"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/pb_loading_apps"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#8B5CF6" />

    <ListView
        android:id="@+id/lv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/btn_save_apps"
        android:layout_below="@id/header_apps"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_save_apps"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button"
        android:text="Save App List"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</RelativeLayout>
